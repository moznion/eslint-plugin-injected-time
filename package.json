{
  "name": "@moznion/eslint-plugin-injected-time",
  "version": "0.0.3",
  "description": "An ESLint and oxlint plugin that forbids ambient Date.now() in your logic and pushes you to inject the current time as a parameter, for deterministic and testable code.",
  "keywords": [
    "date-now",
    "eslint",
    "eslintplugin",
    "oxlint",
    "testability"
  ],
  "license": "MIT",
  "author": "moznion",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moznion/eslint-plugin-injected-time.git"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prelint:eslint": "pnpm run build",
    "lint:eslint": "eslint examples",
    "prelint:oxlint": "pnpm run build",
    "lint:oxlint": "oxlint --format=unix examples",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@typescript-eslint/utils": "8.63.0",
    "eslint": "10.7.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.13.0"
}
